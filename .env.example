PORT=3001
JWT_SECRET=generate-a-random-32-char-string-here
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
DB_PATH=server/data/composed.db
BACKUP_DIR=server/data/backups
GEMINI_API_KEY=your-gemini-api-key-here

# Manus API key for opponent scouting reports (get one at https://manus.im)
MANUS_API_KEY=your-manus-api-key-here

# Google Sign-In (OAuth 2.0 Web Client ID from Google Cloud Console).
# See https://console.cloud.google.com/apis/credentials. Same value for both vars.
# If empty, the Google sign-in button is hidden in the UI and /auth/google/verify returns 503.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
